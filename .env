APP_ENV=prod
APP_SECRET=
APP_SHARE_DIR=var/share

DEFAULT_URI=http://localhost

###> symfony/messenger ###
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=1
###< symfony/messenger ###

POSTGRES_VERSION=18
POSTGRES_DB=
POSTGRES_PASSWORD=
POSTGRES_USER=
POSTGRES_PORT=5432

API_PORT=8080
DB_HOST=database

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?serverVersion=${POSTGRES_VERSION}&charset=utf8"
###< doctrine/doctrine-bundle ###

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL="${REDIS_HOST}://redis:${REDIS_PORT}"
